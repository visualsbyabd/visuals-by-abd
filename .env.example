# ────────────────────────────────────────────────
# Visuals by Abd — Environment Variables
# Copy this file to .env.local and fill in real values.
# ────────────────────────────────────────────────

# Required
MONGODB_URI=mongodb://localhost:27017/visuals-by-abd
AUTH_SECRET=replace-me-with-output-of-openssl-rand-base64-32

# Optional — public app URL (used for password reset / magic link emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email delivery (optional — without these, emails log to console in dev)
# Option A: Resend (recommended)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM="Visuals by Abd <hello@yourdomain.com>"

# Option B: SMTP (Postmark, Gmail, Sendgrid SMTP, etc.)
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-pass

# Seed (optional overrides)
# SEED_ADMIN_EMAIL=admin@visualsbyabd.com
# SEED_ADMIN_PASSWORD=ChangeMeNow_2026!
# SEED_ADMIN_NAME=Abdullah Tharwat
